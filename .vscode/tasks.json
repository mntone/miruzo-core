{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "go build ./cmd/miruzo-api (-Og -g)",
			"type": "shell",
			"command": "make build-api",
			"options": {
				"cwd": "${workspaceFolder}/miruzo"
			},
			"problemMatcher": "$go",
			"group": "build",
			"presentation": {
				"reveal": "silent",
				"panel": "shared"
			}
		},
		{
			"label": "go build ./cmd/miruzo-api && air (-Og -g)",
			"type": "shell",
			"command": "air",
			"options": {
				"cwd": "${workspaceFolder}/miruzo"
			},
			"problemMatcher": [],
			"group": "build",
			"presentation": {
				"reveal": "silent",
				"panel": "shared"
			},
			"isBackground": true,
			"runOptions": {
				"runOn": "folderOpen"
			}
		},
		{
			"label": "go build ./cmd/miruzo-cli (-Og -g)",
			"type": "shell",
			"command": "make build-cli",
			"options": {
				"cwd": "${workspaceFolder}/miruzo"
			},
			"problemMatcher": "$go",
			"group": "build",
			"presentation": {
				"reveal": "silent",
				"panel": "shared"
			}
		},
		{
			"label": "miruzo (Go): sqlc generate",
			"type": "shell",
			"command": "sqlc",
			"args": ["generate"],
			"options": {
				"cwd": "${workspaceFolder}/miruzo/internal/database"
			},
			"problemMatcher": [
				{
					"owner": "sqlc",
					"fileLocation": ["relative", "${workspaceFolder}"],
					"pattern": {
						"regexp": "^(.+):(\\d+):(\\d+):\\s+(.*)$",
						"file": 1,
						"line": 2,
						"column": 3,
						"message": 4
					},
					"severity": "error"
				}
			],
			"group": "build",
			"presentation": {
				"reveal": "silent",
				"panel": "shared"
			}
		}
	]
}
