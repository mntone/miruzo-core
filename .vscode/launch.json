{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "miruzo-api (Debug)",
			"type": "go",
			"request": "launch",
			"mode": "debug",
			"program": "${workspaceFolder}/miruzo/cmd/miruzo-api/main.go",
			"cwd": "${workspaceFolder}/miruzo"
		},
		{
			"name": "miruzo-cli job daily-decay (Debug)",
			"type": "go",
			"request": "launch",
			"mode": "debug",
			"program": "${workspaceFolder}/miruzo/cmd/miruzo-cli",
			"cwd": "${workspaceFolder}/miruzo",
			"args": [
				"job",
				"daily-decay",
			],
		},
		{
			"name": "gataku-import debug",
			"type": "debugpy",
			"cwd": "${workspaceFolder}/miruzo-py",
			"request": "launch",
			"module": "scripts.gataku_import",
			"args": [
				"--limit",
				"${input:limit}",
				"--report-variants"
			],
			"jinja": true
		}
	],
	"inputs": [
		{
			"id": "host",
			"type": "pickString",
			"description": "The host for miruzo API server",
			"default": "0.0.0.0",
			"options": [
				"127.0.0.1",
				"0.0.0.0"
			]
		},
		{
			"id": "port",
			"type": "promptString",
			"description": "The port number for miruzo API server",
			"default": "1024"
		},
		{
			"id": "limit",
			"type": "promptString",
			"description": "The limit for gataku-import",
			"default": "50"
		}
	]
}
